# Copy to terraform.tfvars and edit before running terraform apply
cluster_name           = "documind"
k3d_servers            = 1
k3d_agents             = 2
namespace              = "documind"
api_image_tag          = "latest"
api_replicas           = 3
ollama_model           = "llama3.2:3b"
prometheus_retention   = "15d"
grafana_admin_password = "changeme"
