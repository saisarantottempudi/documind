{
  "title": "DocuMind — Overview",
  "uid": "documind-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["documind", "rag", "mlops"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"documind-api\"}[5m]))",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"documind-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"documind-api\"}[5m])) * 100",
        "legendFormat": "error %"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P99 Latency",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"documind-api\"}[5m]))",
        "legendFormat": "p99"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Pods",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "count(up{job=\"documind-api\"} == 1)",
        "legendFormat": "pods"
      }],
      "options": { "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate by Status Code",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by(status) (rate(http_requests_total{job=\"documind-api\"}[5m]))",
          "legendFormat": "{{ status }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"documind-api\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"documind-api\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"documind-api\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by(handler) (rate(http_requests_total{job=\"documind-api\"}[5m]))",
        "legendFormat": "{{ handler }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Pod Memory Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "container_memory_working_set_bytes{pod=~\"documind-api.*\"}",
        "legendFormat": "{{ pod }}"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Pod CPU Usage",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{pod=~\"documind-api.*\"}[5m])",
        "legendFormat": "{{ pod }}"
      }],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HPA Replica Count",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"documind-api-hpa\"}",
          "legendFormat": "current"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{horizontalpodautoscaler=\"documind-api-hpa\"}",
          "legendFormat": "max"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{horizontalpodautoscaler=\"documind-api-hpa\"}",
          "legendFormat": "min"
        }
      ]
    }
  ]
}
